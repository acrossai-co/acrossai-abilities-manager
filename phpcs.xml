<?xml version="1.0"?>
<ruleset name="AcrossAI Abilities Manager">
	<description>PHPCS configuration for the AcrossAI Abilities Manager plugin.</description>
	<file>acrossai-abilities-manager.php</file>
	<file>includes</file>
	<file>uninstall.php</file>
	<exclude-pattern>vendor/*</exclude-pattern>
	<rule ref="WordPress-Core">
		<!--
			The plugin uses PSR-4 autoloading with PascalCase class filenames.
			WordPress's class-*.php filename convention is incompatible with PSR-4,
			so both filename sniffs are excluded for the includes/ directory.
		-->
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase" />
		<exclude name="WordPress.Files.FileName.InvalidClassFileName" />
	</rule>
	<rule ref="WordPress-Docs" />
	<rule ref="WordPress-Extra" />
	<config name="minimum_supported_wp_version" value="7.0" />
	<arg name="basepath" value="." />
	<arg value="sp" />
</ruleset>
