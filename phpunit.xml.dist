<?xml version="1.0" encoding="UTF-8"?>
<!--
  PHPUnit configuration for the acrossai-abilities-manager plugin.

  Scope: unit tests only — these run against a minimal WP stub bootstrap
  (tests/bootstrap.php) that provides sanitize_text_field, WP_Error, and
  WP_UnitTestCase without requiring a full WordPress installation.

  Integration tests (AbilitiesQueryTest, AbilitiesReadControllerTest,
  AbilitiesWriteControllerTest, AbilitiesExposureControllerTest,
  AbilitiesProcessorTest) require a full WP environment (wp-env + WP_TESTS_DIR)
  and are excluded here. Run them locally with a full WP install.
-->
<phpunit
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.0/phpunit.xsd"
	bootstrap="tests/bootstrap.php"
	colors="true"
	cacheDirectory=".phpunit.cache"
>
	<testsuites>
		<testsuite name="abilities-unit">
			<file>tests/phpunit/abilities/AbilitiesValidationTest.php</file>
			<file>tests/phpunit/abilities/AbilityOverrideInjectVariantATest.php</file>
			<file>tests/phpunit/abilities/SettingsMenuTest.php</file>
		</testsuite>
	</testsuites>
	<source>
		<include>
			<directory suffix=".php">includes/</directory>
		</include>
	</source>
</phpunit>
